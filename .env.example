# Copy to .env on the VPS and set real values (this file is safe to commit; .env is not).
# Used by docker-compose.prod.yml.

# Public domain served by Caddy (must point to the VPS public IP).
SITE_ADDRESS=gsm-xxx.duckdns.org

# PostgreSQL credentials (used by both the postgres container and the app).
DB_NAME=gsmtracker
DB_USER=gsm
DB_PASSWORD=change-me-to-a-strong-password
